generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String           @id @default(uuid())
  dni                     String           @unique
  firstName               String
  lastName                String
  email                   String           @unique
  passwordHash            String
  whatsapp                String?
  birthDate               DateTime?
  role                    String           @default("CUSTOMER")
  points                  Int              @default(0)
  membershipLevel         String           @default("BRONZE")
  isBlocked               Boolean          @default(false)
  isEmailVerified         Boolean          @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  resetCode               String?
  resetCodeExpires        DateTime?
  expoPushToken           String?
  vipRewardSentAt         DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  notifications           Notification[]
  pointHistory            PointHistory[]
  posTransactions         PosTransaction[]
  redemptions             Redemption[]
  visits                  Visit[]
}

model PointHistory {
  id           String   @id @default(uuid())
  userId       String
  pointsGained Int
  source       String
  description  String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Reward {
  id             String       @id @default(uuid())
  name           String
  description    String
  pointsRequired Int
  type           String       @default("BEBIDA")
  imageUrl       String?
  isActive       Boolean      @default(true)
  isAdultOnly    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  redemptions    Redemption[]
}

model Redemption {
  id        String    @id @default(uuid())
  userId    String
  rewardId  String
  status    String    @default("PENDING")
  qrToken   String?   @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  reward    Reward    @relation(fields: [rewardId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model Event {
  id           String   @id @default(uuid())
  title        String
  description  String
  details      String?
  location     String?  @default("Boston Club")
  eventDate    DateTime
  imageUrl     String?
  benefits     String?
  type         String   @default("EVENT")
  buttonText   String?  @default("RESERVAR MESA")
  externalLink String?
  isActive     Boolean  @default(true)
  isAdultOnly  Boolean  @default(false)
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      String   @default("IN_APP")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Visit {
  id           String   @id @default(uuid())
  userId       String
  pointsEarned Int
  checkinTime  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model PromoToken {
  id        String    @id @default(uuid())
  token     String    @unique
  points    Int
  type      String
  expiresAt DateTime?
  isUsed    Boolean   @default(false)
  createdAt DateTime  @default(now())
}

model ClubSettings {
  id                 String   @id @default("singleton")
  vipThreshold       Int      @default(1000)
  checkinPoints      Int      @default(100)
  isEventDay         Boolean  @default(false)
  eventCheckinPoints Int      @default(1000)
  goldThreshold      Int      @default(500000)
  platinumThreshold  Int      @default(1500000)
  diamondThreshold   Int      @default(5000000)
  superVipThreshold  Int      @default(10000000)
  vipMessageTemplate String   @default("¡Felicidades {name}! 🎉 Has llegado a los {points} puntos en Boston Club. ¡Eres un socio VIP! Canjea tus puntos por premios exclusivos.")
  rewardListText     String   @default("- 30% Off en Bebidas\n- Ingreso Free a Eventos\n- Regalo Sorpresa")
  bronceBenefits     String   @default("- Beneficios base de socio\n- Acceso a promociones")
  goldBenefits       String   @default("- 10% Off en toda la carta\n- Mesa reservada los findes")
  platinumBenefits   String   @default("- 20% Off en toda la carta\n- Acceso anticipado a eventos")
  diamondBenefits    String   @default("- 30% Off en toda la carta\n- Zona VIP sin cargo\n- Regalo de cumpleaños")
  superVipBenefits   String   @default("- 50% Off en toda la carta\n- Todo incluido en eventos seleccionados\n- Concierge privado")
  loginVideoUrl      String?
  updatedAt          DateTime @updatedAt
}

model PosTransaction {
  id                String   @id @default(uuid())
  orderId           String   @unique
  userId            String
  amount            Float?
  status            String   @default("PENDING")
  externalPaymentId String?  @unique
  processed         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}
